---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
---

<Layout title="Enquiry Received">
  <SEO
    slot="head"
    title="Enquiry Received"
    description="Thank you — we've received your enquiry and will respond within two business days."
    noindex={true}
  />

  <section class="min-h-[80vh] flex flex-col items-center justify-center px-6 text-center">
    <!-- Accent rule -->
    <div class="w-12 h-px bg-accent mb-10" aria-hidden="true"></div>

    <p class="text-xs uppercase tracking-[0.3em] text-accent mb-4">Enquiry Received</p>

    <h1 class="font-serif text-5xl md:text-6xl text-text mb-6 max-w-xl leading-tight">
      Thank you. We'll be in touch.
    </h1>

    <p class="text-muted text-lg leading-relaxed max-w-md mb-4">
      We've received your enquiry and will send a detailed response within
      <strong class="text-text font-normal">two business days</strong>.
    </p>

    <p class="text-muted leading-relaxed max-w-md mb-12">
      For restoration projects we'll follow up with questions about the car's current
      condition and your goals. For simpler enquiries, we'll often have an initial estimate
      ready in that same response.
    </p>

    <!-- Expected timeline -->
    <div class="bg-surface border border-bg px-10 py-8 mb-12 max-w-sm w-full text-left">
      <h2 class="text-xs uppercase tracking-[0.25em] text-muted mb-5">What to Expect</h2>
      <ol class="space-y-4">
        {[
          { day: 'Day 1', note: 'Confirmation of receipt' },
          { day: 'Day 1–2', note: 'Detailed response with next steps or a starting estimate' },
          { day: 'Week 1–2', note: 'Shop visit or video walk-through, if needed' },
          { day: 'After inspection', note: 'Firm quote' },
        ].map(({ day, note }) => (
          <li class="flex items-start gap-4">
            <span class="text-xs uppercase tracking-widest text-accent shrink-0 mt-0.5 min-w-[4rem]">{day}</span>
            <span class="text-sm text-muted leading-relaxed">{note}</span>
          </li>
        ))}
      </ol>
    </div>

    <!-- Navigation links -->
    <div class="flex flex-col sm:flex-row gap-4 items-center">
      <a
        href="/portfolio"
        class="inline-block px-10 py-4 bg-accent text-text text-xs uppercase tracking-widest hover:bg-accent/80 transition-colors"
      >
        Browse the Portfolio
      </a>
      <a
        href="/services"
        class="inline-block px-10 py-4 border border-metal/40 text-muted text-xs uppercase tracking-widest hover:border-text hover:text-text transition-colors"
      >
        Explore Services
      </a>
    </div>

    <div class="w-12 h-px bg-surface mt-16" aria-hidden="true"></div>
  </section>
</Layout>
