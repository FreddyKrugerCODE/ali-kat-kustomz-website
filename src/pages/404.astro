---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
---

<Layout title="Page Not Found">
  <SEO
    slot="head"
    title="Page Not Found"
    description="The page you're looking for doesn't exist. Head back to explore our portfolio or services."
    noindex={true}
  />

  <section class="min-h-[85vh] flex flex-col items-center justify-center px-6 text-center">
    <!-- Large 404 -->
    <p
      class="font-serif font-bold text-[clamp(6rem,20vw,14rem)] leading-none text-text/[0.05] select-none mb-0"
      aria-hidden="true"
    >
      404
    </p>

    <div class="-mt-4 relative z-10">
      <div class="w-12 h-px bg-accent mx-auto mb-8" aria-hidden="true"></div>

      <p class="text-xs uppercase tracking-[0.3em] text-accent mb-4">Page Not Found</p>

      <h1 class="font-serif text-4xl md:text-5xl text-text mb-6 max-w-md leading-tight">
        This panel hasn't been painted yet.
      </h1>

      <p class="text-muted leading-relaxed max-w-sm mb-10">
        The page you're looking for doesn't exist or has moved. Here are some
        places worth going instead.
      </p>

      <!-- Navigation links -->
      <nav aria-label="Suggested pages" class="flex flex-col sm:flex-row gap-3 justify-center mb-12">
        <a
          href="/"
          class="inline-block px-8 py-3 bg-accent text-text text-xs uppercase tracking-widest hover:bg-accent/80 transition-colors"
        >
          Home
        </a>
        <a
          href="/portfolio"
          class="inline-block px-8 py-3 border border-metal/40 text-muted text-xs uppercase tracking-widest hover:border-text hover:text-text transition-colors"
        >
          Portfolio
        </a>
        <a
          href="/services"
          class="inline-block px-8 py-3 border border-metal/40 text-muted text-xs uppercase tracking-widest hover:border-text hover:text-text transition-colors"
        >
          Services
        </a>
        <a
          href="/contact"
          class="inline-block px-8 py-3 border border-metal/40 text-muted text-xs uppercase tracking-widest hover:border-text hover:text-text transition-colors"
        >
          Contact
        </a>
      </nav>

      <div class="w-12 h-px bg-surface mx-auto" aria-hidden="true"></div>
    </div>
  </section>
</Layout>
