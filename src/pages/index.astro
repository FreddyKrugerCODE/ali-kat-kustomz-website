---
import Layout from '../layouts/Layout.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import Testimonial from '../components/Testimonial.astro';
import { getCollection } from 'astro:content';

// ── Data ──────────────────────────────────────────────────────────────────

const portfolioEntries = (await getCollection('portfolio'))
  .sort((a, b) => b.data.completed_date.getTime() - a.data.completed_date.getTime())
  .slice(0, 6);

const testimonialEntries = (await getCollection('testimonials'))
  .sort((a, b) => {
    // Featured first, then by date desc
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.date.getTime() - a.data.date.getTime();
  })
  .slice(0, 3);

// ── Static data ───────────────────────────────────────────────────────────

const stats = [
  { value: '20+', label: 'Years specialising in vintage refinishing' },
  { value: '340+', label: 'Restorations completed' },
  { value: 'Hagerty',  label: 'Featured in Hagerty & Hemmings' },
  { value: 'SEMA',     label: 'Best Restoration Finish, 2022' },
];

const services = [
  {
    title: 'Full Restoration Paint',
    body: 'From bare metal to final colour sand. Every panel disassembled, prepped, and refinished to factory-correct or custom specifications.',
    href: '/services#restoration',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/>`,
  },
  {
    title: 'Colour Matching & Restoration',
    body: 'Original colour codes, hand-mixed to match aged samples. We document every formula so it can be matched again decades from now.',
    href: '/services#colour-match',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42"/>`,
  },
  {
    title: 'Custom & Commissioned Colour',
    body: 'One-off colours, candies, pearls, and metallics. We build the colour with you, then paint it like it was always meant to be there.',
    href: '/services#custom',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z"/>`,
  },
];

const processSteps = [
  { num: 1, title: 'Intake & Documentation',   desc: 'Photographs, colour analysis, condition report' },
  { num: 2, title: 'Disassembly',               desc: 'Trim, glass, hardware — everything off and catalogued' },
  { num: 3, title: 'Strip to Bare Metal',        desc: 'Media blast or chemical strip, depending on panel' },
  { num: 4, title: 'Bodywork & Block-Sanding',   desc: 'Panel straightening, filler work, guide-coat primer' },
  { num: 5, title: 'Sealer & Colour',            desc: 'Hand-mixed colour, sprayed in our climate-controlled booth' },
  { num: 6, title: 'Clear & Cure',               desc: 'Multiple clear coats, baked, then rested' },
  { num: 7, title: 'Colour Sand & Polish',        desc: 'Wet-sanded flat, machine-polished to final gloss' },
];

const whyChoose = [
  {
    title: 'Climate-controlled environment',
    body: 'Our booth, prep room, and assembly bays are dust-controlled and temperature-stable year-round. Paint behaves better, and so do the people spraying it.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>`,
  },
  {
    title: 'Documented every step',
    body: 'You receive photographs and notes from every stage. Insurance, future buyers, and you — everyone has the record.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>`,
  },
  {
    title: 'Lifetime workmanship guarantee',
    body: 'If we did the work and the paint fails because of how we applied it, we make it right. That\'s been our policy from day one.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/>`,
  },
];
---

<Layout
  title="Ali Kat Kustomz"
  description="Concours-quality custom painting and colour restoration for vintage and classic cars. Hand-mixed colour, bare-metal preparation, lifetime craftsmanship."
>

  <!-- ═══════════════════════════════════════════════════════
       1. HERO
       Full-bleed background image + gradient overlay.
       <img> used (not <Picture>) because the image is in /public.
       When a real JPEG is placed in src/assets/, swap to:
         import heroImg from '../assets/hero.jpg';
         <Picture src={heroImg} widths={[768,1280,1920]} formats={['avif','webp','jpg']} alt="" />
  ════════════════════════════════════════════════════════════ -->
  <section
    class="relative flex items-center justify-center min-h-[100svh] overflow-hidden"
    aria-label="Hero"
  >

    <!-- Background image — decorative, aria-hidden -->
    <img
      src="/images/hero/hero-paint-booth-interior-21x9.webp"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center select-none"
      width="2400"
      height="1029"
      fetchpriority="high"
      decoding="sync"
      loading="eager"
    />

    <!-- Dark gradient overlay: dense at bottom, lighter at top -->
    <div
      class="absolute inset-0 bg-gradient-to-b
             from-bg/40 via-bg/55 to-bg/95"
      aria-hidden="true"
    />

    <!-- Left accent rule -->
    <div class="absolute left-0 top-1/3 w-px h-24 bg-accent" aria-hidden="true" />

    <!-- Content -->
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <p class="text-xs uppercase tracking-[0.35em] text-accent mb-6 font-sans">
        Custom Paint&ensp;&bull;&ensp;Colour Restoration&ensp;&bull;&ensp;Concours Finishing
      </p>

      <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-bold text-text
                 leading-[1.04] text-balance mb-6">
        Paint built to<br class="hidden sm:block" /> outlast the car.
      </h1>

      <p class="text-base sm:text-lg text-text/75 max-w-xl mx-auto leading-relaxed mb-10">
        We restore and refinish vintage automobiles with the patience and
        precision of a craft built one panel at a time. Bare metal to final
        polish, every step done in-house.
      </p>

      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/contact"
          class="px-8 py-3.5 bg-accent text-text font-sans text-xs
                 tracking-[0.2em] uppercase
                 hover:bg-accent/85 active:scale-[0.98]
                 transition-all duration-200"
        >
          Request a Quote
        </a>
        <a
          href="/portfolio"
          class="px-8 py-3.5 border border-metal/60 text-metal font-sans text-xs
                 tracking-[0.2em] uppercase
                 hover:border-text hover:text-text
                 active:scale-[0.98]
                 transition-all duration-200"
        >
          See Our Work
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div
      class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2"
      aria-hidden="true"
    >
      <span class="text-[10px] uppercase tracking-[0.2em] text-muted/60 font-sans">Scroll</span>
      <div class="animate-bounce">
        <svg class="w-5 h-5 text-muted/50" fill="none" stroke="currentColor"
             stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7"/>
        </svg>
      </div>
    </div>

  </section>


  <!-- ═══════════════════════════════════════════════════════
       2. TRUST BAR
  ════════════════════════════════════════════════════════════ -->
  <section aria-label="Credentials" class="border-y border-surface bg-surface/50">
    <div class="max-w-5xl mx-auto px-6">
      <dl
        class="grid grid-cols-2 md:grid-cols-4 divide-x divide-y md:divide-y-0 divide-surface"
      >
        {stats.map(({ value, label }) => (
          <div class="flex flex-col items-center text-center px-6 py-8 gap-2">
            <dt class="font-serif text-3xl font-bold text-text">{value}</dt>
            <dd class="text-[11px] uppercase tracking-[0.18em] text-muted leading-snug">
              {label}
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       3. WHAT WE DO — Three things, done exceptionally well
  ════════════════════════════════════════════════════════════ -->
  <section
    class="max-w-7xl mx-auto px-6 py-24 lg:py-32"
    aria-labelledby="services-heading"
  >
    <div class="max-w-2xl mb-16" data-fade>
      <p class="text-xs uppercase tracking-[0.3em] text-accent mb-4 font-sans">What We Do</p>
      <h2 id="services-heading" class="font-serif text-4xl lg:text-5xl text-text mb-5">
        Three things, done exceptionally well.
      </h2>
      <p class="text-muted leading-relaxed">
        We don't paint daily drivers, fleet vehicles, or production work.
        We paint vintage cars, and we do three things for them.
      </p>
    </div>

    <ul
      class="grid grid-cols-1 md:grid-cols-3 gap-6"
      role="list"
      data-fade
      data-fade-stagger
    >
      {services.map(({ title, body, href, icon }) => (
        <li>
          <a
            href={href}
            class="group flex flex-col h-full bg-surface border border-bg p-8
                   hover:border-accent/30 hover:-translate-y-1
                   transition-all duration-300"
          >
            <!-- Icon -->
            <div class="mb-6 w-10 h-10 flex items-center justify-center
                        border border-metal/20 text-metal
                        group-hover:border-accent/40 group-hover:text-accent
                        transition-colors duration-300">
              <svg class="w-5 h-5" fill="none" stroke="currentColor"
                   stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"
                   set:html={icon} />
            </div>

            <h3 class="font-serif text-xl text-text mb-3
                       group-hover:text-accent transition-colors duration-200">
              {title}
            </h3>

            <p class="text-sm text-muted leading-relaxed flex-1">{body}</p>

            <span class="mt-6 text-[11px] uppercase tracking-[0.2em] text-accent
                         flex items-center gap-2
                         opacity-0 group-hover:opacity-100 translate-x-0
                         group-hover:translate-x-1 transition-all duration-200">
              Learn more
              <svg class="w-3 h-3" fill="none" stroke="currentColor"
                   stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
              </svg>
            </span>
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-12" data-fade>
      <a
        href="/services"
        class="inline-flex items-center gap-2 text-sm text-muted
               hover:text-text transition-colors duration-200
               font-sans uppercase tracking-[0.15em]"
      >
        View All Services
        <svg class="w-4 h-4" fill="none" stroke="currentColor"
             stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       4. FEATURED WORK — 3×2 grid (2×3 tablet, 1col mobile)
  ════════════════════════════════════════════════════════════ -->
  <section
    class="bg-surface py-24 lg:py-32"
    aria-labelledby="portfolio-heading"
  >
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between
                  gap-6 mb-14" data-fade>
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-accent mb-4 font-sans">Recent Projects</p>
          <h2 id="portfolio-heading" class="font-serif text-4xl lg:text-5xl text-text">
            Recent projects.
          </h2>
          <p class="text-muted leading-relaxed mt-4 max-w-lg">
            A look at what's come through the booth lately. Each project
            includes the full story — colour formula, prep notes, and the
            time it took.
          </p>
        </div>
        <a
          href="/portfolio"
          class="flex-shrink-0 text-sm text-muted hover:text-text
                 font-sans uppercase tracking-[0.15em] transition-colors duration-200
                 flex items-center gap-2"
        >
          Browse the Full Portfolio
          <svg class="w-4 h-4" fill="none" stroke="currentColor"
               stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>

      {portfolioEntries.length > 0 ? (
        <ul
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
          role="list"
          data-fade
          data-fade-stagger
        >
          {portfolioEntries.map((entry) => (
            <li>
              <PortfolioCard {entry} />
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-muted text-sm">Portfolio entries coming soon.</p>
      )}
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       5. PROCESS PREVIEW — 7 steps
       Horizontal timeline on desktop (≥md), vertical on mobile.
  ════════════════════════════════════════════════════════════ -->
  <section
    class="max-w-7xl mx-auto px-6 py-24 lg:py-32"
    aria-labelledby="process-heading"
  >
    <div class="max-w-2xl mb-16" data-fade>
      <p class="text-xs uppercase tracking-[0.3em] text-accent mb-4 font-sans">How We Work</p>
      <h2 id="process-heading" class="font-serif text-4xl lg:text-5xl text-text mb-5">
        Seven stages. No shortcuts.
      </h2>
      <p class="text-muted leading-relaxed">
        Great paint isn't sprayed — it's prepared. Most of what we do
        happens before colour ever touches the car.
      </p>
    </div>

    <!-- Desktop: horizontal timeline -->
    <div class="hidden md:block relative" data-fade>
      <!-- Connecting rule — sits behind the numbered circles -->
      <div
        class="absolute inset-x-0 top-5 h-px bg-metal/20"
        aria-hidden="true"
      />

      <ol
        class="relative flex items-start justify-between"
        aria-label="Seven-stage process"
      >
        {processSteps.map(({ num, title, desc }) => (
          <li class="flex flex-col items-center text-center w-0 flex-1 px-1">
            <!-- Numbered circle — bg-bg masks the rule behind it -->
            <div
              class="relative z-10 w-10 h-10 flex-shrink-0
                     border border-accent bg-bg
                     flex items-center justify-center mb-5"
            >
              <span class="font-serif text-accent text-sm font-bold leading-none">
                {String(num).padStart(2, '0')}
              </span>
            </div>
            <h3 class="font-sans text-[11px] font-semibold uppercase tracking-[0.12em]
                       text-text mb-2 leading-snug">
              {title}
            </h3>
            <p class="text-[11px] text-muted leading-snug">{desc}</p>
          </li>
        ))}
      </ol>
    </div>

    <!-- Mobile: vertical list -->
    <ol class="md:hidden space-y-0" aria-label="Seven-stage process" data-fade>
      {processSteps.map(({ num, title, desc }, i) => (
        <li class="flex gap-5 relative">
          <!-- Vertical connector line (except after last item) -->
          {i < processSteps.length - 1 && (
            <div
              class="absolute left-5 top-10 bottom-0 w-px bg-metal/20"
              aria-hidden="true"
            />
          )}

          <!-- Number circle -->
          <div
            class="relative z-10 flex-shrink-0 w-10 h-10
                   border border-accent bg-bg
                   flex items-center justify-center"
          >
            <span class="font-serif text-accent text-sm font-bold leading-none">
              {String(num).padStart(2, '0')}
            </span>
          </div>

          <div class="pb-10">
            <h3 class="font-sans text-sm font-semibold text-text mb-1">{title}</h3>
            <p class="text-sm text-muted leading-relaxed">{desc}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="mt-12" data-fade>
      <a
        href="/process"
        class="inline-flex items-center gap-2 text-sm text-muted
               hover:text-text transition-colors duration-200
               font-sans uppercase tracking-[0.15em]"
      >
        See the Full Process
        <svg class="w-4 h-4" fill="none" stroke="currentColor"
             stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       6. WHY OWNERS CHOOSE US
  ════════════════════════════════════════════════════════════ -->
  <section
    class="bg-surface border-y border-bg py-24 lg:py-32"
    aria-labelledby="why-heading"
  >
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-16" data-fade>
        <p class="text-xs uppercase tracking-[0.3em] text-accent mb-4 font-sans">Why Choose Us</p>
        <h2 id="why-heading" class="font-serif text-4xl lg:text-5xl text-text">
          Built for the long view.
        </h2>
      </div>

      <ul
        class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-16"
        role="list"
        data-fade
        data-fade-stagger
      >
        {whyChoose.map(({ title, body, icon }) => (
          <li>
            <!-- Icon -->
            <div class="mb-6 w-10 h-10 flex items-center justify-center
                        border border-metal/20 text-metal">
              <svg class="w-5 h-5" fill="none" stroke="currentColor"
                   stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"
                   set:html={icon} />
            </div>

            <h3 class="font-serif text-lg text-text mb-3">{title}</h3>
            <p class="text-sm text-muted leading-relaxed">{body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       7. TESTIMONIALS
  ════════════════════════════════════════════════════════════ -->
  <section
    class="max-w-7xl mx-auto px-6 py-24 lg:py-32"
    aria-labelledby="testimonials-heading"
  >
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between
                gap-6 mb-14" data-fade>
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-accent mb-4 font-sans">Client Words</p>
        <h2 id="testimonials-heading" class="font-serif text-4xl lg:text-5xl text-text">
          Owners on what it's like working with us.
        </h2>
      </div>
      <a
        href="/about#testimonials"
        class="flex-shrink-0 text-sm text-muted hover:text-text
               font-sans uppercase tracking-[0.15em] transition-colors duration-200
               flex items-center gap-2"
      >
        Read More Reviews
        <svg class="w-4 h-4" fill="none" stroke="currentColor"
             stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>

    <ul
      class="grid grid-cols-1 md:grid-cols-3 gap-6"
      role="list"
      data-fade
      data-fade-stagger
    >
      {testimonialEntries.map((entry) => (
        <li>
          <Testimonial
            quote={entry.body.trim()}
            author={entry.data.author}
            vehicle={entry.data.vehicle}
            variant="card"
          />
        </li>
      ))}
    </ul>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       8. ABOUT PREVIEW — image left, text right
  ════════════════════════════════════════════════════════════ -->
  <section
    class="bg-surface border-t border-bg py-24 lg:py-32"
    aria-labelledby="about-heading"
  >
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Image column -->
        <div class="relative" data-fade>
          <!-- Accent rule behind the image -->
          <div
            class="absolute -left-4 top-8 bottom-8 w-px bg-accent/40"
            aria-hidden="true"
          />
          <div class="aspect-[3/4] overflow-hidden bg-bg">
            <!--
              When a real shop image is placed in src/assets/, replace with:
              import aboutImg from '../assets/shop.jpg';
              <Picture src={aboutImg} widths={[480, 800]} formats={['avif','webp','jpg']}
                       alt="Inside the Ali Kat Kustomz paint booth" class="w-full h-full object-cover" />
            -->
            <img
              src="/images/hero/hero-about-shop-exterior-21x9.webp"
              alt="Inside the Ali Kat Kustomz paint booth"
              class="w-full h-full object-cover"
              width="2400"
              height="1029"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>

        <!-- Text column -->
        <div data-fade>
          <p class="text-xs uppercase tracking-[0.3em] text-accent mb-5 font-sans">
            About the Shop
          </p>
          <h2 id="about-heading" class="font-serif text-4xl lg:text-5xl text-text mb-6 text-balance">
            A small shop on purpose.
          </h2>
