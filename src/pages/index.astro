<!-- ═══════════════════════════════════════════════════════
     SCROLL ANIMATION
     Progressive enhancement: without JS, [data-fade] elements
     remain hidden (CSS default), but the <noscript> rule in
     Layout.astro restores visibility.
     With JS: IntersectionObserver fires .is-visible when each
     element enters the viewport (with a 50px bottom margin so
     it triggers slightly before the element reaches the edge).
════════════════════════════════════════════════════════════ -->
<script>
  (function initFadeObserver() {
    // Bail if JS animations are unwanted
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const elements = document.querySelectorAll<HTMLElement>('[data-fade]');
    if (!elements.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            // Staggered children: each child already has a CSS transition-delay
            // set by the [data-fade-stagger] rules in global.css, so just add
            // .is-visible to the container and CSS handles the rest.
            observer.unobserve(entry.target);
          }
        }
      },
      {
        // Trigger when element is 10% visible, but 50px before the fold
        threshold: 0.08,
        rootMargin: '0px 0px -50px 0px',
      }
    );

    for (const el of elements) {
      observer.observe(el);
    }
  })();
</script>
