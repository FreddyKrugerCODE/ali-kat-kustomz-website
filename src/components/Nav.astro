---
const navLinks = [
  { href: '/services',  label: 'Services'   },
  { href: '/portfolio', label: 'Portfolio'  },
  { href: '/process',   label: 'Our Process'},
  { href: '/about',     label: 'About'      },
];

// Normalize trailing slash so /portfolio/ and /portfolio both match
const raw     = Astro.url.pathname;
const current = raw.endsWith('/') && raw !== '/' ? raw.slice(0, -1) : raw;
---

<!-- ─── Sticky header bar ─────────────────────────────────────────────── -->
<header
  class="fixed top-0 inset-x-0 z-50 bg-bg/90 backdrop-blur-md border-b border-surface"
>
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between gap-8">

    <!-- Logo -->
    <a
      href="/"
      aria-label="Ali Kat Kustomz — home"
      class="flex-shrink-0 font-serif text-xl font-bold tracking-wide text-text
             hover:text-accent transition-colors duration-200 focus-visible:rounded-sm"
    >
      Ali Kat <span class="text-accent">Kustomz</span>
    </a>

    <!-- Desktop nav links (hidden on mobile) -->
    <nav aria-label="Primary navigation">
      <ul class="hidden md:flex items-center gap-8" role="list">
        {navLinks.map(({ href, label }) => {
          const isCurrent = current === href;
          return (
            <li>
              <a
                href={href}
                aria-current={isCurrent ? 'page' : undefined}
                class:list={[
                  'text-xs font-sans tracking-[0.15em] uppercase transition-colors duration-200',
                  isCurrent
                    ? 'text-accent'
                    : 'text-muted hover:text-text',
                ]}
              >
                {label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <!-- Desktop CTA + mobile toggle -->
    <div class="flex items-center gap-4">
      <!-- "Request a Quote" — desktop only -->
      <a
        href="/contact"
        class="hidden md:inline-flex items-center
               px-5 py-2
               bg-accent text-text
               text-xs font-sans tracking-[0.15em] uppercase
               hover:bg-accent/80 active:scale-95
               transition-all duration-200
               focus-visible:ring-2 focus-visible:ring-text focus-visible:ring-offset-2 focus-visible:ring-offset-accent"
      >
        Request a Quote
      </a>

      <!-- Mobile hamburger toggle -->
      <button
        id="nav-toggle"
        type="button"
        aria-controls="mobile-nav"
        aria-expanded="false"
        aria-label="Open navigation menu"
        class="md:hidden flex flex-col justify-center items-center
               w-10 h-10 -mr-2
               text-muted hover:text-text
               transition-colors duration-200"
      >
        <!-- Hamburger icon (visible when closed) -->
        <span id="icon-menu" aria-hidden="true" class="block">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </span>
        <!-- Close (×) icon (visible when open) -->
        <span id="icon-close" aria-hidden="true" class="hidden block">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </span>
      </button>
    </div>

  </div>
</header>

<!-- ─── Full-screen mobile nav overlay ───────────────────────────────────
     Starts invisible + inert so it's fully removed from keyboard/AT flow.
     JS removes [inert] and transitions opacity/translate when opened.
     role="dialog" + aria-modal="true" confines screen-reader navigation.
──────────────────────────────────────────────────────────────────────── -->
<div
  id="mobile-nav"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  aria-hidden="true"
  inert
  class="fixed inset-0 z-[60]
         bg-bg
         flex flex-col
         opacity-0 translate-y-2
         transition-all duration-300 ease-out"
>

  <!-- Overlay header row: logo + close button -->
  <div class="flex items-center justify-between px-6 h-16 border-b border-surface flex-shrink-0">
    <a
      href="/"
      class="font-serif text-xl font-bold tracking-wide text-text"
      tabindex="-1"
      id="overlay-logo"
    >
      Ali Kat <span class="text-accent">Kustomz</span>
    </a>

    <button
      id="nav-close"
      type="button"
      aria-label="Close navigation menu"
      class="flex items-center justify-center w-10 h-10 -mr-2
             text-muted hover:text-text transition-colors duration-200"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Nav links — centered, large type -->
  <nav aria-label="Mobile navigation" class="flex-1 flex flex-col justify-center px-8">
    <ul role="list" class="space-y-1">
      {navLinks.map(({ href, label }) => {
        const isCurrent = current === href;
        return (
          <li>
            <a
              href={href}
              aria-current={isCurrent ? 'page' : undefined}
              class:list={[
                'group flex items-center gap-3 py-4',
                'font-serif text-4xl sm:text-5xl font-bold leading-none',
                'border-b border-surface/60',
                'transition-colors duration-200',
                isCurrent
                  ? 'text-accent'
                  : 'text-text hover:text-accent',
              ]}
            >
              <span class="text-accent text-base font-sans tracking-widest opacity-0 group-hover:opacity-100 group-[aria-current=page]:opacity-100 transition-opacity duration-200 -mb-1">
                &#x2014;
              </span>
              {label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>

  <!-- Overlay footer: CTA + contact snippet -->
  <div class="flex-shrink-0 px-8 pb-10 pt-6 border-t border-surface flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
    <a
      href="/contact"
      class="inline-flex items-center
             px-8 py-3
             bg-accent text-text
             text-xs font-sans tracking-[0.2em] uppercase
             hover:bg-accent/80 active:scale-95
             transition-all duration-200"
    >
      Request a Quote
    </a>
    <address class="not-italic text-sm text-muted leading-relaxed">
      <a href="mailto:kustomz.ali.kat@gmail.com" class="hover:text-text transition-colors">
        kustomz.ali.kat@gmail.com
      </a><br />
      <a href="tel:+15625427296" class="hover:text-text transition-colors">
        (562) 542-7296
      </a>
    </address>
  </div>

</div>

<!-- ─── Script ─────────────────────────────────────────────────────────── -->
<script>
  const toggle  = document.getElementById('nav-toggle')  as HTMLButtonElement;
  const overlay = document.getElementById('mobile-nav')  as HTMLDivElement;
  const closeBtn = document.getElementById('nav-close')  as HTMLButtonElement;
  const iconMenu  = document.getElementById('icon-menu')  as HTMLSpanElement;
  const iconClose = document.getElementById('icon-close') as HTMLSpanElement;

  // ── Helpers ────────────────────────────────────────────────────────────

  function getAllFocusable(): HTMLElement[] {
    return Array.from(
      overlay.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
      )
    );
  }

  function openNav(): void {
    // 1. Make overlay interactive before the visual transition
    overlay.removeAttribute('inert');
    overlay.removeAttribute('aria-hidden');

    // 2. Trigger transition (requestAnimationFrame ensures initial state painted first)
    requestAnimationFrame(() => {
      overlay.classList.remove('opacity-0', 'translate-y-2');
      overlay.classList.add('opacity-100', 'translate-y-0');
    });

    // 3. Update toggle button state
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Close navigation menu');
    iconMenu.classList.add('hidden');
    iconClose.classList.remove('hidden');

    // 4. Prevent body scroll
    document.body.classList.add('nav-open');

    // 5. Move focus to the close button (first tabbable element in overlay)
    closeBtn.focus();
  }

  function closeNav(): void {
    // 1. Start visual transition
    overlay.classList.add('opacity-0', 'translate-y-2');
    overlay.classList.remove('opacity-100', 'translate-y-0');

    // 2. Mark as hidden for AT immediately (doesn't need to wait for animation)
    overlay.setAttribute('aria-hidden', 'true');

    // 3. Restore inert after the CSS transition completes (300 ms)
    setTimeout(() => {
      overlay.setAttribute('inert', '');
    }, 300);

    // 4. Update toggle button state
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open navigation menu');
    iconMenu.classList.remove('hidden');
    iconClose.classList.add('hidden');

    // 5. Re-enable body scroll
    document.body.classList.remove('nav-open');

    // 6. Return focus to the toggle button
    toggle.focus();
  }

  // ── Focus trap ─────────────────────────────────────────────────────────

  overlay.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') {
      closeNav();
      return;
    }

    if (e.key !== 'Tab') return;

    const focusable = getAllFocusable();
    const first = focusable[0];
    const last  = focusable[focusable.length - 1];

    if (e.shiftKey) {
      // Shift+Tab from first element → wrap to last
      if (document.activeElement === first) {
        e.preventDefault();
        last.focus();
      }
    } else {
      // Tab from last element → wrap to first
      if (document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });

  // ── Event listeners ────────────────────────────────────────────────────

  toggle.addEventListener('click', () => {
    toggle.getAttribute('aria-expanded') === 'true' ? closeNav() : openNav();
  });

  closeBtn.addEventListener('click', closeNav);

  // Close on Escape from anywhere in the document (catches overlay links too)
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
      closeNav();
    }
  });

  // Close when a mobile nav link is followed (SPA-style or same-page anchor)
  overlay.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((link) => {
    link.addEventListener('click', () => {
      // Small delay so the navigation can start before overlay closes
      setTimeout(closeNav, 50);
    });
  });
</script>
