---
interface Props {
  quote: string;
  author: string;
  vehicle?: string;
  /** URL to a portrait photo. When omitted, an initials avatar is rendered. */
  photo?: string;
  /** Override the auto-generated initials (e.g. "D.R.") */
  initials?: string;
  /** Compact left-border style used in sidebars; default is card style */
  variant?: 'card' | 'bar';
}

const {
  quote,
  author,
  vehicle,
  photo,
  initials: initialsOverride,
  variant = 'card',
} = Astro.props;

// Generate 1–2 letter initials from "First L." or "First Last"
function toInitials(name: string): string {
  const parts = name.trim().split(/\s+/);
  if (parts.length === 1) return parts[0][0].toUpperCase();
  return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
}

const initials = initialsOverride ?? toInitials(author);
---

{variant === 'bar' ? (
  <!-- Sidebar / accent-bar style (original) -->
  <figure class="bg-surface border-l-2 border-accent p-8">
    <blockquote class="font-serif text-lg text-text leading-relaxed mb-6 italic">
      &ldquo;{quote}&rdquo;
    </blockquote>
    <figcaption class="text-sm text-muted">
      <span class="font-sans font-semibold text-metal">{author}</span>
      {vehicle && <span class="ml-2 text-muted">&mdash; {vehicle}</span>}
    </figcaption>
  </figure>
) : (
  <!-- Card style with avatar -->
  <figure class="bg-surface border border-bg p-8 flex flex-col gap-6">
    <!-- Quote mark -->
    <svg
      class="w-8 h-8 text-accent/40 flex-shrink-0"
      fill="currentColor"
      viewBox="0 0 32 32"
      aria-hidden="true"
    >
      <path d="M10 8C6.686 8 4 10.686 4 14v10h10V14H7.333C7.333 11.42 8.42 9.333 10 8ZM24 8c-3.314 0-6 2.686-6 6v10h10V14h-6.667C21.333 11.42 22.42 9.333 24 8Z"/>
    </svg>

    <blockquote class="font-serif text-base sm:text-lg text-text leading-relaxed italic flex-1">
      {quote}
    </blockquote>

    <figcaption class="flex items-center gap-4 pt-4 border-t border-bg">
      <!-- Avatar -->
      {photo ? (
        <img
          src={photo}
          alt={author}
          class="w-12 h-12 rounded-full object-cover flex-shrink-0"
          width="48"
          height="48"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div
          class="w-12 h-12 rounded-full bg-metal/20 border border-metal/30
                 flex items-center justify-center flex-shrink-0"
          aria-hidden="true"
        >
          <span class="font-serif text-sm font-bold text-metal">{initials}</span>
        </div>
      )}

      <div>
        <p class="text-sm font-sans font-semibold text-text">{author}</p>
        {vehicle && (
          <p class="text-xs text-muted mt-0.5">{vehicle}</p>
        )}
      </div>
    </figcaption>
  </figure>
)}
