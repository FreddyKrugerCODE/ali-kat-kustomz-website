---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'portfolio'>;
}

const { entry } = Astro.props;
const { year, make, model, era, services, hero, color_name, title } = entry.data;
const displayTitle = title ?? `${year} ${make} ${model}`;
---

<a
  href={`/portfolio/${entry.slug}`}
  class="group block bg-surface overflow-hidden border border-bg hover:border-accent/30 transition-all duration-300 hover:-translate-y-1"
  data-era={era}
  data-make={make}
>
  <div class="aspect-[4/3] overflow-hidden bg-bg">
    <img
      src={hero}
      alt={displayTitle}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
      decoding="async"
      width="800"
      height="600"
    />
  </div>

  <div class="p-6">
    <div class="flex items-center justify-between mb-1">
      <p class="text-xs uppercase tracking-widest text-accent">{year}</p>
      <p class="text-xs uppercase tracking-widest text-muted">{era}</p>
    </div>
    <h3 class="font-serif text-xl text-text mb-1 group-hover:text-accent transition-colors">
      {make} {model}
    </h3>
    {color_name && (
      <p class="text-xs text-muted mb-3 italic">{color_name}</p>
    )}
    <ul class="flex flex-wrap gap-2 mt-2">
      {services.slice(0, 3).map((service) => (
        <li class="text-xs bg-bg text-muted px-2 py-1">{service}</li>
      ))}
      {services.length > 3 && (
        <li class="text-xs bg-bg text-muted px-2 py-1">+{services.length - 3} more</li>
      )}
    </ul>
  </div>
</a>
