---
interface Props {
  step: number;
  title: string;
  description: string;
}

const { step, title, description } = Astro.props;
---

<div class="flex gap-6 items-start">
  <div class="flex-shrink-0 w-12 h-12 border border-accent flex items-center justify-center">
    <span class="font-serif text-accent font-bold text-lg">{step.toString().padStart(2, '0')}</span>
  </div>
  <div>
    <h3 class="font-serif text-lg text-text mb-2">{title}</h3>
    <p class="text-sm text-muted leading-relaxed">{description}</p>
  </div>
</div>
